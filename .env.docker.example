WEB_PORT=3001
WEB_IMAGE=ghcr.io/etic-club/s2ee-2026:latest

# External Postgres container on your VPS.
DATABASE_URL=postgresql://project:change-me@postgres-container-or-vps-ip:5432/project

# Public URL where users reach this app.
BETTER_AUTH_URL=https://your-domain.example
CORS_ORIGIN=https://your-domain.example
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Existing MinIO instance. Create this bucket in MinIO before starting the app.
S3_ENDPOINT=https://minio.your-domain.example
S3_BUCKET=s2ee-ralph
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_REGION=us-east-1
