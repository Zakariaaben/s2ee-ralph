{
  "name": "project",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "tailwindcss": "^4.1.18",
      "better-auth": "1.5.2",
      "@effect/vitest": "^4.0.0-beta.31",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "@typescript/native-preview": "^7.0.0-dev.20250906.1",
      "@effect/atom-react": "^4.0.0-beta.31",
      "@effect/sql-pg": "^4.0.0-beta.31",
      "effect": "^4.0.0-beta.31",
      "vitest": "^4.1.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:vitest": "turbo run test:vitest",
    "test:bun": "turbo run test:bun",
    "typecheck": "turbo run typecheck",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "db:push": "turbo run db:push -F @project/db",
    "db:studio": "turbo run db:studio -F @project/db",
    "db:generate": "turbo run db:generate -F @project/db",
    "db:migrate": "turbo run db:migrate -F @project/db",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@project/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@project/config": "workspace:*",
    "@types/node": "catalog:",
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.5",
  "module": "index.ts"
}
